  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EvidenceInteractable
  evidenceId: A2
  evidenceDisplayName: Taxi Ride Receipt
  evidenceDescription: "A digital taxi receipt showing a departure from the office
    at 9:47 PM, destination listed as a residential address. Alex claims this proves
    they left before the incident. However, the fare shows NO 'Late Night Fee' surcharge
    \u2014 a charge automatically applied by the platform to all rides dispatched
    after 9:00 PM. Compare with P2 to confirm the surcharge should be present. This
    receipt appears to be fabricated."
  previewModelPrefab: {fileID: 1213132792}
  changeColorOnInspect: 1
  inspectedColor: {r: 0.4, g: 0.4, b: 0.4, a: 1}
  targetRenderer: {fileID: 0}

  m_Script: {fileID: 11500000, guid: 548e311e6bca8a440a71dd08f901f5c0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EvidenceInteractable
  evidenceId: P2
  evidenceDisplayName: Late-Night Taxi Receipt
  evidenceDescription: "A digital taxi receipt showing the Project Manager departed
    from a nearby office complex at 9:14 PM. The route and distance are comparable
    to Alex's receipt (A2). Notably, the fare includes an itemised 'Late Night Fee'
    surcharge \u2014 a standard charge automatically applied to all rides dispatched
    after 9:00 PM. Alex's receipt (A2) covers a similar route at 9:47 PM yet shows
    NO such surcharge, exposing it as fabricated."
  previewModelPrefab: {fileID: 1940644772}
  changeColorOnInspect: 1
  inspectedColor: {r: 0.4, g: 0.4, b: 0.4, a: 1}
  targetRenderer: {fileID: 0}
